<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ttt.one.waiguagg.dao.InfoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.ttt.one.waiguagg.entity.InfoEntity" id="infoMap">
        <result property="id" column="id"/>
        <result property="waiguaType" column="waigua_type"/>
        <result property="waiguaDescribe" column="waigua_describe"/>
        <result property="waiguaId" column="waigua_id"/>
        <result property="reportuserId" column="reportuser_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updataTime" column="updata_time"/>
        <result property="status" column="status"/>
        <result property="reviewStatus" column="review_status"/>
        <result property="waiguaUsername" column="waigua_username"/>
        <result property="thumbUpNumber" column="thumb_up_number"/>
        <result property="readNumber" column="read_number"/>
    </resultMap>
    <insert id="saveInfoReturnId" parameterType="com.ttt.one.waiguagg.entity.InfoEntity"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO waigua_info(waigua_type, waigua_describe, waigua_id,reportuser_id,create_time,updata_time,status
        ,review_status,waigua_username,thumb_up_number,read_number)
        VALUES(#{waiguaType}, #{waiguaDescribe}, #{waiguaId},#{reportuserId},#{createTime},#{updataTime},#{status}
        ,#{reviewStatus},#{waiguaUsername},#{thumbUpNumber},#{readNumber});
    </insert>
    <select id="findListAll" resultType="com.ttt.one.waiguagg.entity.InfoEntity">
        SELECT i.* , IF
            ( g.id IS NULL, 0, 1 ) AS isSupport
        FROM waigua_info i
                 LEFT JOIN waigua_giveLike g ON g.relation_id = i.id AND g.user_id = #{currentUser} AND g.type = #{type}
        WHERE i.`status` = 0
        <if test="reviewStatus != null and reviewStatus != ''">
            AND i.review_status = #{reviewStatus}
        </if>
        <if test="key != null and key != ''">
            AND c.waiguaDescribe LIKE CONCAT( '%', #{key}, '%' )
        </if>

    </select>
    <select id="getByIdAndCuser" resultType="com.ttt.one.waiguagg.entity.InfoEntity">
        SELECT i.* , IF
            ( g.id IS NULL, 0, 1 ) AS isSupport
        FROM waigua_info i
                 LEFT JOIN waigua_giveLike g ON g.relation_id = i.id AND g.user_id = #{currentUser} AND g.type = #{type}
        WHERE i.`status` = 0 AND i.id = #{id}
    </select>
    <select id="findListByUser" resultType="com.ttt.one.waiguagg.entity.InfoEntity">
        SELECT i.*,
               f.location,f.audio_duration AS audioDuration,f.cover
        FROM `waigua_info` i
                 LEFT JOIN waigua_file_info f ON f.waigua_info_id = i.id
        where i.reportuser_id = #{reportuserId} and i.`status` = 0
        <if test="reviewStatus != null and reviewStatus != ''">
            AND i.review_status = #{reviewStatus}
        </if>
        <if test="key != null and key != ''">
            AND i.waiguaUsername LIKE CONCAT( '%', #{key}, '%' )
        </if>
        <if test="pageSize != null and pageSize != ''">
        LIMIT ${pageIndex},${pageSize}
        </if>
    </select>


</mapper>
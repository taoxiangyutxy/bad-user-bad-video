<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ttt.one.fileServer.dao.FileInfoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.ttt.one.fileServer.entity.FileInfoEntity" id="fileInfoMap">
        <result property="id" column="id"/>
        <result property="filename" column="filename"/>
        <result property="identifier" column="identifier"/>
        <result property="location" column="location"/>
        <result property="totalSize" column="total_size"/>
        <result property="type" column="type"/>
        <result property="waiguaInfoId" column="waigua_info_id"/>
        <result property="createTime" column="create_time"/>
        <result property="audioDuration" column="audio_duration"/>
        <result property="cover" column="cover"/>
    </resultMap>
        <insert id="saveFile" parameterType="com.ttt.one.fileServer.entity.FileInfoEntity"
                useGeneratedKeys="true" keyProperty="id" keyColumn="id">
            INSERT INTO waigua_file_info(filename, identifier, location,total_size,type,waigua_info_id,create_time,audio_duration,cover)
            VALUES(#{filename}, #{identifier}, #{location},#{totalSize},#{type},#{waiguaInfoId},#{createTime},#{audioDuration},#{cover});
        </insert>
    <update id="updateByIdentifiers">
        UPDATE  waigua_file_info  SET  waigua_info_id = #{waiguaInfoId}  , create_time= #{createTime} ,  cover = #{cover}  WHERE  identifier  in
        <foreach collection="identifiers" index="index" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </update>
    <update id="updateFileById" parameterType="com.ttt.one.fileServer.entity.FileInfoEntity"
            useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        UPDATE  waigua_file_info  SET  waigua_info_id = #{waiguaInfoId}  , create_time= #{createTime} ,  cover = #{cover}, identifier = #{identifier}
                                  ,filename = #{filename} , location = #{location} ,total_size = #{totalSize} ,type = #{type} ,audio_duration = #{audioDuration}
                                  WHERE  id = #{id}
    </update>
    <select id="listByPass" resultType="com.ttt.one.fileServer.entity.FileInfoEntity">
        SELECT f.* FROM `waigua_file_info` f
        LEFT JOIN  waigua_info i ON i.id = f.waigua_info_id
        WHERE i.review_status = 2
    </select>
    <select id="listByPassAndExpired" resultType="com.ttt.one.fileServer.entity.FileInfoEntity">
        SELECT f.* FROM `waigua_file_info` f
        LEFT JOIN  waigua_info i ON i.id = f.waigua_info_id
        WHERE i.review_status = 2
        and f.create_time  &lt;  DATE_SUB(NOW(), INTERVAL 7 DAY)
    </select>


</mapper>
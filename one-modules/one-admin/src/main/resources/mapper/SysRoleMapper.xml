<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ttt.one.admin.dao.SysRoleMapper">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.ttt.one.admin.entity.SysRole" id="sysRoleMap">
        <result property="roleId" column="role_id"/>
        <result property="roleName" column="role_name"/>
        <result property="description" column="description"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <select id="listPermsByRoleId" resultType="com.ttt.one.admin.entity.SysMenu">
        SELECT m.* FROM sys_menu m
        LEFT JOIN sys_role_menu rm On rm.menu_id = m.menu_id
        WHERE rm.role_id = #{roleId}

    </select>
    <select id="findByUserId" resultType="com.ttt.one.admin.entity.SysRole">
        SELECT r.* FROM sys_role r
        LEFT JOIN sys_user_role sur ON r.role_id = sur.role_id
        WHERE sur.user_id = #{userId}
    </select>


</mapper>
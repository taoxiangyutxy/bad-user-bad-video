<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ttt.one.admin.dao.SysMenuMapper">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.ttt.one.admin.entity.SysMenu" id="sysMenuMap">
        <result property="menuId" column="menu_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="menuName" column="menu_name"/>
        <result property="path" column="path"/>
        <result property="perms" column="perms"/>
        <result property="type" column="type"/>
        <result property="icon" column="icon"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
        <result property="component" column="component"/>
        <result property="isVisible" column="is_visible"/>
    </resultMap>

    <!-- 根据用户ID查询菜单列表，支持动态条件 -->
    <select id="selectMenusByUserId" resultType="com.ttt.one.admin.entity.SysMenu">
        SELECT DISTINCT m.* FROM sys_menu m
        INNER JOIN sys_role_menu rm ON m.menu_id = rm.menu_id
        INNER JOIN sys_user_role ur ON rm.role_id = ur.role_id
        WHERE ur.user_id = #{userId}
        <if test="menuType != null and menuType != ''">
            AND m.type = #{menuType}
        </if>
        <if test="isVisible != null">
            AND m.is_visible = #{isVisible}
        </if>
        ORDER BY m.sort_order
    </select>

    <!-- 查询根菜单，支持动态条件 -->
    <select id="selectRootMenus" resultType="com.ttt.one.admin.entity.SysMenu">
        SELECT * FROM sys_menu
        WHERE parent_id = 0
        <if test="menuType != null and menuType != ''">
            AND type = #{menuType}
        </if>
        ORDER BY sort_order
    </select>

    <!-- 根据父菜单ID查询子菜单，支持动态条件 -->
    <select id="selectChildrenByParentId" resultType="com.ttt.one.admin.entity.SysMenu">
        SELECT * FROM sys_menu
        WHERE parent_id = #{parentId}
        <if test="menuType != null and menuType != ''">
            AND type = #{menuType}
        </if>
        <if test="isVisible != null">
            AND is_visible = #{isVisible}
        </if>
        ORDER BY sort_order
    </select>

    <!-- 查询菜单树，支持多种动态条件 -->
    <select id="selectMenuTree" resultType="com.ttt.one.admin.entity.SysMenu">
        SELECT * FROM sys_menu
        <where>
            <if test="condition.parentId != null">
                AND parent_id = #{condition.parentId}
            </if>
            <if test="condition.menuType != null and condition.menuType != ''">
                AND type = #{condition.menuType}
            </if>
            <if test="condition.isVisible != null">
                AND is_visible = #{condition.isVisible}
            </if>
            <if test="condition.menuName != null and condition.menuName != ''">
                AND menu_name LIKE CONCAT('%', #{condition.menuName}, '%')
            </if>
            <choose>
                <when test="condition.statusList != null and condition.statusList.size() > 0">
                    AND status IN
                    <foreach collection="condition.statusList" item="status" open="(" separator="," close=")">
                        #{status}
                    </foreach>
                </when>
                <when test="condition.status != null">
                    AND status = #{condition.status}
                </when>
            </choose>
        </where>
        ORDER BY sort_order, create_time
    </select>
    <select id="findByRoleId" resultType="com.ttt.one.admin.entity.SysMenu">
        SELECT m.* FROM sys_menu m
        LEFT JOIN sys_role_menu rm ON m.menu_id = rm.menu_id
        WHERE rm.role_id = #{roleId}
    </select>
    <select id="getRoleNamesByMenuId" resultType="java.lang.String">
        SELECT r.role_name FROM sys_role r
        LEFT JOIN sys_role_menu rm ON r.role_id = rm.role_id
        WHERE rm.menu_id = #{menuId}
    </select>
</mapper>